{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Arcane Shield",
  "version": "0.1.0",
  "identifier": "com.arcane.shield",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Arcane Shield",
        "width": 1400,
        "height": 900,
        "minWidth": 1000,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
